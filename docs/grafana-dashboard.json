{
  "dashboard": {
    "id": null,
    "uid": "healthcare-referral-routing",
    "title": "Healthcare Referral Routing",
    "description": "Real-time monitoring of the patient referral intake and routing pipeline",
    "tags": ["azure", "healthcare", "logic-apps", "service-bus"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "annotations": {
      "list": []
    },
    "panels": [
      {
        "id": 1,
        "title": "Referral Pipeline Overview",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Total Referrals Received",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Log Analytics",
            "azureLogAnalytics": {
              "query": "AzureDiagnostics\n| where ResourceProvider == \"MICROSOFT.LOGIC\"\n| where resource_workflowName_s endswith \"-intake\"\n| where OperationName == \"Microsoft.Logic/workflows/workflowRunCompleted\"\n| summarize Total=count(), TimeGenerated=max(TimeGenerated)",
              "resources": ["${LAW_WORKSPACE_RESOURCE_ID}"],
              "resultFormat": "table",
              "timeColumn": "TimeGenerated"
            }
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "blue", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Urgent Referrals",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${SB_NAMESPACE}",
              "metricDefinition": "Microsoft.ServiceBus/namespaces",
              "metricName": "IncomingMessages",
              "timeGrain": "auto",
              "dimensionFilters": [
                {
                  "dimension": "EntityName",
                  "operator": "eq",
                  "filters": ["urgent-referrals"]
                }
              ],
              "aggregation": "Total"
            }
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "dark-red", "value": null },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Standard Referrals",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${SB_NAMESPACE}",
              "metricDefinition": "Microsoft.ServiceBus/namespaces",
              "metricName": "IncomingMessages",
              "timeGrain": "auto",
              "dimensionFilters": [
                {
                  "dimension": "EntityName",
                  "operator": "eq",
                  "filters": ["standard-referrals"]
                }
              ],
              "aggregation": "Total"
            }
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "dark-green", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Validation Errors",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Log Analytics",
            "azureLogAnalytics": {
              "query": "AzureDiagnostics\n| where ResourceProvider == \"MICROSOFT.LOGIC\"\n| where resource_workflowName_s endswith \"-intake\"\n| where OperationName == \"Microsoft.Logic/workflows/workflowRunCompleted\"\n| summarize ValidationErrors=countif(status_s == \"Failed\"), TimeGenerated=max(TimeGenerated)",
              "resources": ["${LAW_WORKSPACE_RESOURCE_ID}"],
              "resultFormat": "table",
              "timeColumn": "TimeGenerated"
            }
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Logic App Workflows",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
        "collapsed": false
      },
      {
        "id": 7,
        "title": "Intake Logic App — Runs Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "Succeeded",
            "queryType": "Azure Log Analytics",
            "azureLogAnalytics": {
              "query": "AzureDiagnostics\n| where ResourceProvider == \"MICROSOFT.LOGIC\"\n| where resource_workflowName_s endswith \"-intake\"\n| where OperationName == \"Microsoft.Logic/workflows/workflowRunCompleted\"\n| summarize Succeeded=countif(status_s == \"Succeeded\"), Failed=countif(status_s == \"Failed\") by bin(TimeGenerated, 5m)\n| order by TimeGenerated asc",
              "resources": ["${LAW_WORKSPACE_RESOURCE_ID}"],
              "resultFormat": "time_series",
              "timeColumn": "TimeGenerated"
            }
          }
        ],
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "list", "placement": "bottom" }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80,
              "stacking": { "mode": "normal" }
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Succeeded" },
              "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "Failed" },
              "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Router Logic App — Runs Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Log Analytics",
            "azureLogAnalytics": {
              "query": "AzureDiagnostics\n| where ResourceProvider == \"MICROSOFT.LOGIC\"\n| where resource_workflowName_s endswith \"-router\"\n| where OperationName == \"Microsoft.Logic/workflows/workflowRunCompleted\"\n| summarize Succeeded=countif(status_s == \"Succeeded\"), Failed=countif(status_s == \"Failed\") by bin(TimeGenerated, 5m)\n| order by TimeGenerated asc",
              "resources": ["${LAW_WORKSPACE_RESOURCE_ID}"],
              "resultFormat": "time_series",
              "timeColumn": "TimeGenerated"
            }
          }
        ],
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "list", "placement": "bottom" }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80,
              "stacking": { "mode": "normal" }
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Succeeded" },
              "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "Failed" },
              "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
            }
          ]
        }
      },
      {
        "id": 9,
        "title": "Service Bus Queues",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
        "collapsed": false
      },
      {
        "id": 10,
        "title": "Queue Message Flow",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 16, "x": 0, "y": 17 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "Incoming",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${SB_NAMESPACE}",
              "metricDefinition": "Microsoft.ServiceBus/namespaces",
              "metricName": "IncomingMessages",
              "timeGrain": "PT1M",
              "dimensionFilters": [
                {
                  "dimension": "EntityName",
                  "operator": "eq",
                  "filters": ["incoming-referrals", "urgent-referrals", "standard-referrals"]
                }
              ],
              "aggregation": "Total"
            }
          }
        ],
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "pointSize": 6,
              "showPoints": "always"
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 11,
        "title": "Active Messages per Queue",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${SB_NAMESPACE}",
              "metricDefinition": "Microsoft.ServiceBus/namespaces",
              "metricName": "ActiveMessages",
              "timeGrain": "PT1M",
              "dimensionFilters": [
                {
                  "dimension": "EntityName",
                  "operator": "eq",
                  "filters": ["incoming-referrals", "urgent-referrals", "standard-referrals"]
                }
              ],
              "aggregation": "Average"
            }
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "API Gateway",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
        "collapsed": false
      },
      {
        "id": 13,
        "title": "APIM Requests (Total / Success / Failed)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "Total",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${APIM_NAME}",
              "metricDefinition": "Microsoft.ApiManagement/service",
              "metricName": "TotalRequests",
              "timeGrain": "PT1M",
              "aggregation": "Total"
            }
          },
          {
            "refId": "Successful",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${APIM_NAME}",
              "metricDefinition": "Microsoft.ApiManagement/service",
              "metricName": "SuccessfulRequests",
              "timeGrain": "PT1M",
              "aggregation": "Total"
            }
          },
          {
            "refId": "Failed",
            "queryType": "Azure Monitor",
            "azureMonitor": {
              "resourceGroup": "${RG}",
              "resourceName": "${APIM_NAME}",
              "metricDefinition": "Microsoft.ApiManagement/service",
              "metricName": "FailedRequests",
              "timeGrain": "PT1M",
              "aggregation": "Total"
            }
          }
        ],
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "list", "placement": "bottom" }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80,
              "stacking": { "mode": "normal" }
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Recent Referral Activity",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "${DS_AZURE_MONITOR}"
        },
        "targets": [
          {
            "refId": "A",
            "queryType": "Azure Log Analytics",
            "azureLogAnalytics": {
              "query": "AzureDiagnostics\n| where ResourceProvider == \"MICROSOFT.LOGIC\"\n| where Category == \"WorkflowRuntime\"\n| where OperationName == \"Microsoft.Logic/workflows/workflowRunCompleted\"\n| project Time=TimeGenerated, Workflow=resource_workflowName_s, Status=status_s, TrackingId=correlation_clientTrackingId_s\n| order by Time desc\n| take 15",
              "resources": ["${LAW_WORKSPACE_RESOURCE_ID}"],
              "resultFormat": "table",
              "timeColumn": "Time"
            }
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Time", "desc": true }]
        },
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Status" },
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "type": "color-text"
                  }
                },
                {
                  "id": "mappings",
                  "value": [
                    { "type": "value", "options": { "Succeeded": { "color": "green", "text": "Succeeded" } } },
                    { "type": "value", "options": { "Failed": { "color": "red", "text": "Failed" } } }
                  ]
                }
              ]
            }
          ]
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "DS_AZURE_MONITOR",
          "type": "datasource",
          "query": "grafana-azure-monitor-datasource",
          "current": {},
          "hide": 0,
          "label": "Azure Monitor"
        }
      ]
    }
  },
  "overwrite": true
}
