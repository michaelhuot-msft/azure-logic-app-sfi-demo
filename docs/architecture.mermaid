%% Azure Logic Apps Healthcare Referral Routing — Architecture Diagram
%% Render at https://mermaid.live or in any Mermaid-compatible viewer

flowchart TB
    subgraph client["Client"]
        direction TB
        PS["test-referral.ps1"]
    end

    subgraph apimLayer["API Gateway"]
        direction TB
        APIM["API Management<br/><i>Consumption Tier</i><br/>Rate Limit: 10 req/min<br/>Subscription Key Required"]
    end

    subgraph intake["Stage 1 — Intake"]
        direction TB
        LA1["Logic App: Referral Intake<br/><i>System-Assigned Managed Identity</i>"]
        LA1_V["Validate Schema<br/>6 required fields"]
        LA1_E["Enrich<br/>+ correlationId<br/>+ receivedAt<br/>+ status"]
        LA1 --> LA1_V --> LA1_E
    end

    subgraph bus["Azure Service Bus <i>(Standard Tier)</i>"]
        direction TB
        Q1["incoming-referrals<br/><i>intake output</i>"]
        Q2["urgent-referrals<br/><i>priority = urgent | high</i>"]
        Q3["standard-referrals<br/><i>priority = normal | low</i>"]
    end

    subgraph router["Stage 2 — Router"]
        direction TB
        LA2["Logic App: Referral Router<br/><i>System-Assigned Managed Identity</i>"]
        LA2_P["Parse Message"]
        LA2_C{"Priority<br/>Check"}
        LA2 --> LA2_P --> LA2_C
    end

    subgraph crosscut["Cross-Cutting Services"]
        direction LR
        KV["Key Vault<br/><i>RBAC Authorization</i><br/>Stores SB Connection String"]
        LAW["Log Analytics Workspace<br/><i>30-day Retention</i><br/>Diagnostics from All Resources"]
        MI["Managed Identity + RBAC<br/><i>No Passwords Anywhere</i><br/>SB Data Sender/Receiver<br/>KV Secrets User"]
    end

    PS -->|"HTTPS POST + API Key"| APIM
    APIM -->|"Proxy to callback URL"| LA1
    LA1_E -->|"Send Message"| Q1
    Q1 -->|"Dequeue (poll 30s)"| LA2
    LA2_C -->|"urgent / high"| Q2
    LA2_C -->|"normal / low"| Q3
    LA1 -.->|"202 Accepted + correlationId"| PS

    KV -.->|"secrets"| LA1
    KV -.->|"secrets"| LA2
    LAW -.->|"diagnostics"| APIM
    LAW -.->|"diagnostics"| LA1
    LAW -.->|"diagnostics"| LA2
    LAW -.->|"diagnostics"| Q1
    MI -.->|"authenticates"| LA1
    MI -.->|"authenticates"| LA2

    classDef clientStyle fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    classDef apimStyle fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#bf360c
    classDef logicStyle fill:#e8eaf6,stroke:#283593,stroke-width:2px,color:#1a237e
    classDef busStyle fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20
    classDef urgentStyle fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c
    classDef standardStyle fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20
    classDef securityStyle fill:#fce4ec,stroke:#880e4f,stroke-width:2px,color:#880e4f
    classDef observeStyle fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#4a148c
    classDef identityStyle fill:#efebe9,stroke:#4e342e,stroke-width:2px,color:#3e2723
    classDef decisionStyle fill:#fff9c4,stroke:#f57f17,stroke-width:2px,color:#e65100

    class PS clientStyle
    class APIM apimStyle
    class LA1,LA1_V,LA1_E logicStyle
    class LA2,LA2_P logicStyle
    class Q1 busStyle
    class Q2 urgentStyle
    class Q3 standardStyle
    class KV securityStyle
    class LAW observeStyle
    class MI identityStyle
    class LA2_C decisionStyle
